# Base del proxy REST de Binance.
# En desarrollo NO hace falta definirla: Vite proxya /binance → data-api.binance.vision.
# En producción, despliega el Worker (worker/) y pon aquí su URL:
# VITE_BINANCE_PROXY=https://cripto-elliott-binance-proxy.tu-subdominio.workers.dev

# Opcional: Demo API key de CoinGecko (sube el rate limit del free tier).
# VITE_COINGECKO_KEY=CG-xxxxxxxxxxxxxxxx
